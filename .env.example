# База данных
DATABASE_URL=postgresql://user:pass@localhost:5432/datamind

# Защита API (заголовок X-API-Key). Пусто = защита выключена (локальная разработка).
API_KEY=

# LLM (polza.ai — OpenAI-совместимый шлюз)
POLZA_API_KEY=pza_...
POLZA_BASE_URL=https://api.polza.ai/api/v1
LLM_MODEL=deepseek/deepseek-v4-flash

# Selectel S3
SELECTEL_ENDPOINT=https://s3.selectel.ru
SELECTEL_ACCESS_KEY=
SELECTEL_SECRET_KEY=
SELECTEL_BUCKET=datamind-files
